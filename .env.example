# ── Data Reliability Autopilot Configuration ──────────────────────────────────
# Copy this file to .env and update values as needed.

# AI Backend: "ollama" (default), "openai", or "none"
AUTOPILOT_AI_BACKEND=ollama

# Ollama Settings (for local LLM inference)
AUTOPILOT_OLLAMA_URL=http://localhost:11434/api/generate
AUTOPILOT_OLLAMA_MODEL=llama3
AUTOPILOT_OLLAMA_TIMEOUT=120

# OpenAI Settings (if using OpenAI backend)
AUTOPILOT_OPENAI_API_KEY=
AUTOPILOT_OPENAI_MODEL=gpt-4o-mini
AUTOPILOT_OPENAI_TIMEOUT=60

# DuckDB Database Path (use :memory: for in-memory)
AUTOPILOT_DB_PATH=:memory:

# Data Directory
AUTOPILOT_DATA_DIR=./data

# Sandbox Settings
AUTOPILOT_SANDBOX_TIMEOUT=30
AUTOPILOT_SANDBOX_MAX_ROWS=10000

# Debug Mode
AUTOPILOT_DEBUG=false
